# OddLock Environment Configuration
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=OddLock

# ── GenLayer Contract ────────────────────────────────────────────────────────
# Deploy OddLockReferee.py to GenLayer Studionet, then paste the address here.
# Without this, the app runs in local-draft-only mode.
NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS=

# ── GenLayer Network ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GENLAYER_CHAIN_ID=61999
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api
NEXT_PUBLIC_GENLAYER_EXPLORER_URL=https://explorer-studio.genlayer.com

# ── App Settings ─────────────────────────────────────────────────────────────
# Currency display mode: INTERNAL_TEST_UNITS (display-friendly) or NATIVE_GEN_WEI
NEXT_PUBLIC_CURRENCY_MODE=INTERNAL_TEST_UNITS

# Enable localStorage drafts (recommended for testnet use)
NEXT_PUBLIC_USE_LOCAL_DRAFTS=true
